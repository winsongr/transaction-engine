APP_NAME="Transaction Engine"
ENV="development" # development | production

# === Database ===
# Connection details for the primary Postgres database.
# In docker-compose, these match the 'postgres' service.
POSTGRES_SERVER="localhost"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="transaction_engine"
POSTGRES_PORT=5432
# Optional: Completely override the constructed URI
# DATABASE_URL="postgresql+asyncpg://user:pass@host:port/dbname"

# === Redis ===
# Used for Caching and Distributed Locks.
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0
# Optional: Completely override the constructed URI
# REDIS_URL="redis://localhost:6379/0"

# === Kafka / Redpanda ===
# Bootstrap servers for event streaming.
KAFKA_BOOTSTRAP_SERVERS="localhost:9092"

# === Security ===
# Origins allowed to access the API via CORS.
BACKEND_CORS_ORIGINS='["http://localhost:3000", "http://localhost:8000"]'
# Hosts allowed to access the application (Host header validation).
ALLOWED_HOSTS='["localhost", "127.0.0.1", "0.0.0.0"]'

# === Logging ===
LOG_LEVEL="INFO"
